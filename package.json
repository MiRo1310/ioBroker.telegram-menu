{
  "name": "iobroker.telegram-menu",
  "version": "4.2.2",
  "description": "Easily create Telegram Menus",
  "author": {
    "name": "MiRo1310",
    "email": "michael.roling@gmx.de"
  },
  "homepage": "https://github.com/MiRo1310/ioBroker.telegram-menu",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "telegram",
    "menu"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MiRo1310/ioBroker.telegram-menu.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.17.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react-v5": "^8.1.8",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@mui/lab": "^7.0.1-beta.25",
    "@mui/material": "^7.3.9",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.19",
    "@types/proxyquire": "^1.3.31",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "nyc": "^18.0.0",
    "proxyquire": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build",
    "build",
    "www/",
    "io-package.json",
    "LICENSE",
    "admin/**/style.css",
    "admin/build/index.js.map"
  ],
  "scripts": {
    "prebuild": "npm run lint:fix && rimraf admin/build",
    "build": "npm run build:react && npm run tsc",
    "watch": "build-adapter react --watch",
    "tsc": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prebuild:react": "rimraf admin/build",
    "build:react": "build-adapter react",
    "watch:react": "build-adapter react --watch",
    "test:ts": "mocha -r ts-node/register -r tsconfig-paths/register \"test/**/*.test.ts\" --config test/mocharc.custom.json",
    "test:watch": "mocha -r ts-node/register -r tsconfig-paths/register \"test/**/*.test.ts\" --config test/mocharc.custom.json --watch",
    "test:ts:debug": "mocha -r ts-node/register -r tsconfig-paths/register \"test/**/*.test.ts\" --config test/mocharc.custom.json --inspect-brk",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha -r ts-node/register test/integration.ts --exit",
    "test": "npm run test:ts && npm run test:package",
    "test:unit": "nyc --reporter=text-summary npm run test:ts",
    "test:cov": "nyc --reporter=html npm run test:ts",
    "test:cov:ci": "nyc npm run test:ts",
    "lint": "eslint -c eslint.config.mjs . && eslint -c admin/eslint.config.mjs admin/src/",
    "lint:fix": "eslint -c eslint.config.mjs . --fix && eslint -c admin/eslint.config.mjs admin/src/ --fix",
    "lint:backend": "eslint -c eslint.config.mjs .",
    "lint:frontend": "eslint -c admin/eslint.config.mjs admin/src/",
    "translate": "translate-adapter",
    "release": "release-script",
    "checker": "node skript.mjs",
    "dev": " dev-server run",
    "reset": "git reset $(git merge-base main $(git rev-parse --abbrev-ref HEAD))",
    "force": "git push --force-with-lease"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "test/**/*.ts"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "all": true,
    "require": [
      "ts-node/register",
      "tsconfig-paths/register"
    ]
  },
  "bugs": {
    "url": "https://github.com/MiRo1310/ioBroker.telegram-menu/issues"
  },
  "readmeFilename": "README.md"
}
